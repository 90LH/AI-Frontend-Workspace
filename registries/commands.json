      "description": "生成定位和修复 Bug 的 AI 输入。",
      "version": "1.0.0",
      "parameters": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string",
            "description": "Bug 描述或错误信息。"
          },
          "file": {
            "type": "string",
            "description": "观察到 Bug 的文件路径。"
          },
          "reproduction": {
