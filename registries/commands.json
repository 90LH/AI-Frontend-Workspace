    {
      "id": "command:new-page",
      "name": "new-page",
      "description": "生成创建 Vue 路由级页面的 AI 输入。",
      "version": "1.0.0",
      "parameters": {
        "type": "object",
        "properties": {
          "page_name": {
            "type": "string",
            "description": "页面名称。"
          },
          "route_path": {
            "type": "string",
            "description": "路由路径。"
          },
          "description": {
            "type": "string",
            "description": "页面功能描述。"
          },
          "layout": {
            "type": "string",
            "description": "Layout 组件。"
          },
          "store": {
            "type": "boolean",
            "description": "是否需要创建 Pinia store slice。",
            "default": false
          }
        },
        "required": [
          "page_name",
          "route_path",
          "description"
        ]
      },
      "dependencies": [
        "skill:vue-page-create",
        "skill:component-analysis",
        "agent:architect",
        "agent:developer",
        "agent:reviewer"
      ],
      "execution": {
        "type": "generate-prompt",
        "resourceId": "command:new-page"
      }
    },
    {
      "id": "command:new-component",
      "name": "new-component",
      "description": "生成创建可复用组件的 AI 输入。",
      "version": "1.0.0",
      "parameters": {
        "type": "object",
        "properties": {
          "component_name": {
            "type": "string",
            "description": "组件名称。"
          },
          "type": {
            "type": "string",
            "description": "组件类型或使用场景。"
          },
          "description": {
            "type": "string",
            "description": "组件能力描述。"
          }
        },
        "required": [
          "component_name",
          "description"
        ]
      },
